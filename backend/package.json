{
  "name": "feature-toggle-backend",
  "version": "1.0.0",
  "description": "Backend API for feature toggle management with PostgreSQL and Redis",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "psql -h ${DB_HOST:-localhost} -U ${DB_USER:-confuse} -d ${DB_NAME:-confuse_shared} -f ../database/schema.sql"
  },
  "dependencies": {
    "express": "^5.2.1",
    "cors": "^2.8.6",
    "helmet": "^8.2.0",
    "pg": "^8.22.0",
    "redis": "^6.0.0",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.20.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}